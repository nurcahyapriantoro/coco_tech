# ── Dependencies ──────────────────────────────────────────────────────────
backend/node_modules/
frontend/node_modules/

# ── Environment variables — NEVER commit secrets ──────────────────────────
backend/.env
frontend/.env

# ── SQLite database files — contain live data ─────────────────────────────
data/*.db
data/*.db-shm
data/*.db-wal

# ── Frontend production build — generated, not source ─────────────────────
frontend/dist/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS artifacts ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor directories ─────────────────────────────────────────────────────
.vscode/
.idea/
