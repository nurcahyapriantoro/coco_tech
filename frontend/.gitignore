# ──────────────────────────────────────────────
# CocoTech Frontend — .gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/

# Build output — DO App Platform builds this, don't commit
dist/
dist-ssr/

# Environment variables — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.production
.env.staging

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite cache
.vite/
